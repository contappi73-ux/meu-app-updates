import tkinter as tk
from tkinter import messagebox, ttk
import customtkinter as ctk
import google.generativeai as genai
import json
import os
from PIL import Image
from pathlib import Path

# --- CONFIGURAÇÃO DE CAMINHOS (PASTA OCULTA EM DOCUMENTOS) ---
pasta_docs = Path(os.path.expanduser("~")) / "Documents"
pasta_config = pasta_docs / ".config_sistema"

# Cria a pasta se não existir
if not pasta_config.exists():
    pasta_config.mkdir(parents=True, exist_ok=True)
    # No Windows, este comando oculta a pasta de verdade
    if os.name == 'nt':
        import ctypes
        ctypes.windll.kernel32.SetFileAttributesW(str(pasta_config), 2)

ARQUIVOS = {
    "respostas": pasta_config / "respostas_rapidas.json",
    "historico": pasta_config / "historico.json",
    "regras_est": pasta_config / "regras_estruturadas.json",
    "regras_txt": pasta_config / "regras_texto_livre.txt",
    "logo": pasta_config / "logo.png"
}

# --- CONFIGURAÇÕES DE IA ---
API_KEY = "AIzaSyDe4or7G0JAXSt3ViD1M2Efg-3w_MG92dM"
genai.configure(api_key=API_KEY)
model = genai.GenerativeModel('gemini-2.5-flash')

# --- FUNÇÕES DE DADOS ---
def carregar_json(arq, padrao):
    if arq.exists():
        try:
            with open(arq, "r", encoding="utf-8") as f: return json.load(f)
        except: return padrao
    return padrao

def salvar_json(arq, dados):
    with open(arq, "w", encoding="utf-8") as f:
        json.dump(dados, f, ensure_ascii=False, indent=4)

# --- CLASSE PRINCIPAL ---
class App(ctk.CTk):
    def __init__(self):
        super().__init__()

        # Carregar Dados
        self.lista_respostas = carregar_json(ARQUIVOS["respostas"], ["Olá! Boa noite.", "Vou verificar."])
        self.historico_ia = carregar_json(ARQUIVOS["historico"], [])
        self.regras_est = carregar_json(ARQUIVOS["regras_est"], [{"infração": "Spam", "punicao": "Mute 1 dia"}])
        
        self.regras_txt = ""
        if ARQUIVOS["regras_txt"].exists():
            self.regras_txt = ARQUIVOS["regras_txt"].read_text(encoding="utf-8")

        # Layout Janela
        self.title("Sistema de Gestão IA - @defaulzzj")
        self.geometry("1100x750")
        ctk.set_appearance_mode("dark")
        
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(0, weight=1)

        # Sidebar
        self.sidebar = ctk.CTkFrame(self, width=220, corner_radius=0)
        self.sidebar.grid(row=0, column=0, sticky="nsew")
        
        # Tenta carregar logo da pasta oculta
        try:
            img = ctk.CTkImage(Image.open(ARQUIVOS["logo"]), size=(160, 50))
            self.logo_label = ctk.CTkLabel(self.sidebar, image=img, text="")
        except:
            self.logo_label = ctk.CTkLabel(self.sidebar, text="MODERADOR IA", font=("Segoe UI", 22, "bold"))
        self.logo_label.pack(pady=30)

        self.add_menu_item("📝 Correção de Texto", "correcao")
        self.add_menu_item("🛡️ IA de Moderação", "mod")
        self.add_menu_item("📜 Histórico", "hist")
        self.add_menu_item("⚙️ Configurações", "config")

        # Container
        self.container = ctk.CTkFrame(self, fg_color="#121212", corner_radius=15)
        self.container.grid(row=0, column=1, padx=20, pady=20, sticky="nsew")
        
        self.current_frame = None
        self.frames = {}
        self.init_screens()
        self.show_screen("correcao")

    def add_menu_item(self, text, target):
        btn = ctk.CTkButton(self.sidebar, text=text, anchor="w", height=45, fg_color="transparent", 
                            hover_color="#2b2b2b", corner_radius=8, command=lambda: self.show_screen(target))
        btn.pack(fill="x", padx=15, pady=5)
        return btn

    def init_screens(self):
        self.frames["correcao"] = self.screen_correcao()
        self.frames["mod"] = self.screen_mod()
        self.frames["hist"] = self.screen_hist()
        self.frames["config"] = self.screen_config()

    def show_screen(self, name):
        if self.current_frame: self.current_frame.pack_forget()
        self.current_frame = self.frames[name]
        self.current_frame.pack(fill="both", expand=True, padx=20, pady=20)

    # --- TELA CORREÇÃO ---
    def screen_correcao(self):
        f = ctk.CTkFrame(self.container, fg_color="transparent")
        ctk.CTkLabel(f, text="Corretor de Texto", font=("Segoe UI", 20, "bold")).pack(pady=10)
        self.txt_input = ctk.CTkTextbox(f, height=250, corner_radius=15)
        self.txt_input.pack(fill="x", pady=10)
        
        ctk.CTkButton(f, text="CORRIGIR E COPIAR", height=50, fg_color="#2ecc71", command=self.acao_corrigir).pack(pady=10)
        self.status = ctk.CTkLabel(f, text="Status: Pronto", text_color="gray")
        self.status.pack()

        self.scroll_resp = ctk.CTkScrollableFrame(f, orientation="horizontal", height=70)
        self.scroll_resp.pack(fill="x", pady=10)
        self.refresh_resp_btns()
        return f

    # --- REINSTALANDO O BOTÃO DIREITO ---
    def refresh_resp_btns(self):
        for w in self.scroll_resp.winfo_children(): w.destroy()
        for r in self.lista_respostas:
            btn = ctk.CTkButton(self.scroll_resp, text=r, fg_color="#2c3e50")
            btn.pack(side="left", padx=5)
            # Clique esquerdo: Copia
            btn.configure(command=lambda t=r: self.quick_copy(t))
            # Clique direito: Menu para remover
            btn.bind("<Button-3>", lambda e, t=r: self.menu_remover(e, t))

    def menu_remover(self, event, texto):
        menu = tk.Menu(self, tearoff=0, bg="#2b2b2b", fg="white", borderwidth=0)
        menu.add_command(label="❌ Remover Resposta", command=lambda: self.remover_resposta_rapida(texto))
        menu.post(event.x_root, event.y_root)

    def remover_resposta_rapida(self, texto):
        if texto in self.lista_respostas:
            self.lista_respostas.remove(texto)
            salvar_json(ARQUIVOS["respostas"], self.lista_respostas)
            self.refresh_resp_btns()

    def quick_copy(self, t):
        self.clipboard_clear(); self.clipboard_append(t)
        self.status.configure(text="Copiado!", text_color="#2ecc71")

    # --- TELA MODERAÇÃO ---
    def screen_mod(self):
        f = ctk.CTkFrame(self.container, fg_color="transparent")
        self.mod_chat = ctk.CTkTextbox(f, state="disabled", corner_radius=15)
        self.mod_chat.pack(fill="both", expand=True, pady=10)
        
        entry_f = ctk.CTkFrame(f, fg_color="transparent")
        entry_f.pack(fill="x")
        self.mod_entry = ctk.CTkEntry(entry_f, placeholder_text="O que aconteceu?", height=45)
        self.mod_entry.pack(side="left", fill="x", expand=True, padx=(0,10))
        ctk.CTkButton(entry_f, text="Analisar", width=100, command=self.acao_moderar).pack(side="right")
        return f

    def acao_moderar(self):
        txt = self.mod_entry.get()
        if not txt: return
        self.update_mod_chat(f"👤 Caso: {txt}")
        
        reg_est = "\n".join([f"- {r['infração']}: {r['punicao']}" for r in self.regras_est])
        prompt = f"Use estas regras:\n{reg_est}\nRegulamento:\n{self.regras_txt}\n\nAnalise o caso: {txt}"
        
        try:
            res = model.generate_content(prompt).text.strip()
            self.update_mod_chat(f"🤖 Sugestão: {res}\n")
            self.mod_entry.delete(0, "end")
        except: pass

    def update_mod_chat(self, m):
        self.mod_chat.configure(state="normal")
        self.mod_chat.insert("end", m + "\n")
        self.mod_chat.configure(state="disabled")
        self.mod_chat.see("end")

    # --- TELA HISTÓRICO ---
    def screen_hist(self):
        f = ctk.CTkFrame(self.container, fg_color="transparent")
        self.box_h = tk.Listbox(f, bg="#1a1a1a", fg="white", borderwidth=0)
        self.box_h.pack(fill="both", expand=True, pady=10)
        ctk.CTkButton(f, text="Copiar Selecionado", command=self.copiar_h).pack()
        self.refresh_hist()
        return f

    def refresh_hist(self):
        self.box_h.delete(0, "end")
        for h in self.historico_ia: self.box_h.insert("end", h)

    def copiar_h(self):
        try:
            sel = self.box_h.get(self.box_h.curselection())
            self.clipboard_clear(); self.clipboard_append(sel)
        except: pass

    # --- TELA CONFIGURAÇÕES ---
    def screen_config(self):
        f = ctk.CTkScrollableFrame(self.container, fg_color="transparent")
        
        ctk.CTkLabel(f, text="⚖️ Adicionar Regra Estruturada").pack(anchor="w")
        self.e_inf = ctk.CTkEntry(f, placeholder_text="Infração"); self.e_inf.pack(fill="x", pady=2)
        self.e_pun = ctk.CTkEntry(f, placeholder_text="Punição"); self.e_pun.pack(fill="x", pady=2)
        ctk.CTkButton(f, text="Adicionar", command=self.add_regra).pack(pady=5)
        
        ctk.CTkLabel(f, text="📖 Regulamento Completo (Texto Livre)").pack(anchor="w", pady=(20,0))
        self.txt_livre = ctk.CTkTextbox(f, height=200)
        self.txt_livre.pack(fill="x", pady=5)
        self.txt_livre.insert("1.0", self.regras_txt)
        ctk.CTkButton(f, text="Salvar Texto Livre", command=self.salvar_txt).pack()

        ctk.CTkButton(f, text="+ Resposta Rápida", command=self.add_resp_rapida, fg_color="#34495e").pack(pady=20)
        return f

    def add_resp_rapida(self):
        nova = simpledialog_askstring("Nova", "Texto da resposta rápida:")
        if nova:
            self.lista_respostas.append(nova)
            salvar_json(ARQUIVOS["respostas"], self.lista_respostas)
            self.refresh_resp_btns()

    def add_regra(self):
        if self.e_inf.get() and self.e_pun.get():
            self.regras_est.append({"infração": self.e_inf.get(), "punicao": self.e_pun.get()})
            salvar_json(ARQUIVOS["regras_est"], self.regras_est)
            self.e_inf.delete(0, "end"); self.e_pun.delete(0, "end")

    def salvar_txt(self):
        self.regras_txt = self.txt_livre.get("1.0", "end-1c")
        ARQUIVOS["regras_txt"].write_text(self.regras_txt, encoding="utf-8")
        messagebox.showinfo("Sucesso", "Salvo!")

    def acao_corrigir(self):
        t = self.txt_input.get("1.0", "end-1c").strip()
        if not t: return
        try:
            res = model.generate_content(f"Corrija apenas o texto: {t}").text.strip()
            self.historico_ia.insert(0, res)
            salvar_json(ARQUIVOS["historico"], self.historico_ia[:50])
            self.clipboard_clear(); self.clipboard_append(res)
            self.status.configure(text="Sucesso!", text_color="#2ecc71")
            self.refresh_hist()
        except: pass

def simpledialog_askstring(title, prompt):
    return tk.simpledialog.askstring(title, prompt)

if __name__ == "__main__":
    app = App()
    app.mainloop()
